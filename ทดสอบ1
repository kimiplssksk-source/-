function Library:CreateToggle(parent, labelText, defaultOn, callback)
    local row = Instance.new("Frame")
    row.Parent = parent
    row.BackgroundTransparency = 1
    row.Size = UDim2.new(1, 0, 0, 24)

    local lbl = Instance.new("TextLabel")
    lbl.Parent = row
    lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(1, -45, 1, 0)
    lbl.Font = Enum.Font.Gotham
    lbl.Text = labelText
    lbl.TextColor3 = Color3.fromRGB(210, 200, 240)
    lbl.TextSize = 11
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    local btn = Instance.new("TextButton")
    btn.Parent = row
    btn.AnchorPoint = Vector2.new(1, 0.5)
    btn.Position = UDim2.new(1, 0, 0.5, 0)
    btn.Size = UDim2.new(0, 36, 0, 18)
    btn.Text = ""
    btn.AutoButtonColor = false
    btn.BackgroundColor3 = Color3.fromRGB(30, 15, 50)

    Instance.new("UICorner", btn).CornerRadius = UDim.new(1, 0)

    local knob = Instance.new("Frame")
    knob.Parent = btn
    knob.Size = UDim2.new(0, 14, 0, 14)
    knob.Position = UDim2.new(0, 2, 0.5, -7)
    knob.BackgroundColor3 = Color3.fromRGB(200, 200, 255)
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local on = defaultOn or false
    local function render()
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3 = on and Color3.fromRGB(100, 30, 180) or Color3.fromRGB(30, 15, 50)}):Play()
        TweenService:Create(knob, TweenInfo.new(0.2), {Position = on and UDim2.new(1, -16, 0.5, -7) or UDim2.new(0, 2, 0.5, -7)}):Play()
        TweenService:Create(knob, TweenInfo.new(0.2), {BackgroundColor3 = on and Color3.fromRGB(255, 100, 200) or Color3.fromRGB(200, 200, 255)}):Play()
    end
    render()

    btn.MouseButton1Click:Connect(function()
        on = not on
        render()
        if callback then callback(on) end
    end)
end

function Library:CreateSlider(parent, labelText, minV, maxV, defaultV, callback)
    local wrap = Instance.new("Frame")
    wrap.Parent = parent
    wrap.BackgroundTransparency = 1
    wrap.Size = UDim2.new(1, 0, 0, 35)

    local lbl = Instance.new("TextLabel")
    lbl.Parent = wrap
    lbl.BackgroundTransparency = 1
    lbl.Size = UDim2.new(1, -45, 0, 14)
    lbl.Font = Enum.Font.Gotham
    lbl.Text = labelText
    lbl.TextColor3 = Color3.fromRGB(210, 200, 240)
    lbl.TextSize = 11
    lbl.TextXAlignment = Enum.TextXAlignment.Left

    local valueLbl = Instance.new("TextLabel")
    valueLbl.Parent = wrap
    valueLbl.AnchorPoint = Vector2.new(1, 0)
    valueLbl.Position = UDim2.new(1, 0, 0, 0)
    valueLbl.Size = UDim2.new(0, 40, 0, 14)
    valueLbl.BackgroundTransparency = 1
    valueLbl.Font = Enum.Font.GothamBold
    valueLbl.Text = tostring(defaultV)
    valueLbl.TextColor3 = Color3.fromRGB(255, 150, 255)
    valueLbl.TextSize = 11
    valueLbl.TextXAlignment = Enum.TextXAlignment.Right

    local bar = Instance.new("TextButton")
    bar.Parent = wrap
    bar.Position = UDim2.new(0, 0, 0, 20)
    bar.Size = UDim2.new(1, 0, 0, 6)
    bar.BackgroundColor3 = Color3.fromRGB(30, 15, 50)
    bar.Text = ""
    bar.AutoButtonColor = false
    Instance.new("UICorner", bar).CornerRadius = UDim.new(1, 0)

    local fill = Instance.new("Frame")
    fill.Parent = bar
    fill.Size = UDim2.new(0, 0, 1, 0)
    fill.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", fill).CornerRadius = UDim.new(1, 0)
    
    local fillGrad = Instance.new("UIGradient")
    fillGrad.Parent = fill
    fillGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(150, 50, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 200, 255))
    })

    local knob = Instance.new("Frame")
    knob.Parent = bar
    knob.Size = UDim2.new(0, 12, 0, 12)
    knob.AnchorPoint = Vector2.new(0.5, 0.5)
    knob.Position = UDim2.new(0, 0, 0.5, 0)
    knob.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    Instance.new("UICorner", knob).CornerRadius = UDim.new(1, 0)

    local dragging = false
    
    local function update(input)
        local barAbsPos = bar.AbsolutePosition.X
        local barAbsSize = bar.AbsoluteSize.X
        local mousePos = input.Position.X
        
        local alpha = math.clamp((mousePos - barAbsPos) / barAbsSize, 0, 1)
        local v = math.floor(minV + (maxV - minV) * alpha)
        
        valueLbl.Text = tostring(v)
        fill.Size = UDim2.new(alpha, 0, 1, 0)
        knob.Position = UDim2.new(alpha, 0, 0.5, 0)
        
        if callback then callback(v) end
    end

    local startAlpha = math.clamp((defaultV - minV) / (maxV - minV), 0, 1)
    fill.Size = UDim2.new(startAlpha, 0, 1, 0)
    knob.Position = UDim2.new(startAlpha, 0, 0.5, 0)

    bar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            update(input)
        end
    end)

    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            update(input)
        end
    end)
end

