-- ระบบลาก
function Library:MakeDraggable(obj)
    local dragging, dragInput, dragStart, startPos
    obj.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = obj.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    obj.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            obj.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
end

-- ฟังก์ชันเอฟเฟกต์คลื่น (รวมศูนย์ไว้ตรงนี้)
function Library:RippleEffect(button, input)
    local ripple = Instance.new("Frame")
    ripple.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    ripple.BackgroundTransparency = 0.6
    ripple.AnchorPoint = Vector2.new(0.5, 0.5)
    
    local x = math.clamp(input.Position.X - button.AbsolutePosition.X, 0, button.AbsoluteSize.X)
    local y = math.clamp(input.Position.Y - button.AbsolutePosition.Y, 0, button.AbsoluteSize.Y)
    ripple.Position = UDim2.new(0, x, 0, y)
    ripple.Size = UDim2.new(0, 0, 0, 0)
    
    local corner = Instance.new("UICorner", ripple)
    corner.CornerRadius = UDim.new(1, 0)
    
    local clipper = Instance.new("Frame", button)
    clipper.Name = "Clipper"
    clipper.Size = UDim2.new(1, 0, 1, 0)
    clipper.BackgroundTransparency = 1
    clipper.ClipsDescendants = true
    local clipCorner = Instance.new("UICorner", clipper)
    clipCorner.CornerRadius = UDim.new(0, 5)
    
    ripple.Parent = clipper
    
    local maxSize = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 2.5
    
    TweenService:Create(ripple, TweenInfo.new(0.5, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, maxSize, 0, maxSize),
        BackgroundTransparency = 1
    }):Play()
    
    task.delay(0.5, function()
        if clipper and clipper.Parent then
            clipper:Destroy()
        end
    end)
end

-- [[ ระบบ Tab ]]
function Library:CreateTab(name, iconId)
    local TabBtn = Instance.new("TextButton")
    TabBtn.Name = name .. "Btn"
    TabBtn.Parent = self.SideBar
    TabBtn.BackgroundColor3 = Color3.fromRGB(25, 15, 40)
    TabBtn.Size = UDim2.new(1, -6, 0, 28)
    TabBtn.Font = Enum.Font.Gotham
    TabBtn.Text = name
    TabBtn.TextColor3 = Color3.fromRGB(180, 160, 220)
    TabBtn.TextSize = 11
    TabBtn.TextXAlignment = Enum.TextXAlignment.Left
    TabBtn.AutoButtonColor = false

    local UIPadding = Instance.new("UIPadding")
    UIPadding.Parent = TabBtn
    UIPadding.PaddingLeft = UDim.new(0, 28)

    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 5)
    BtnCorner.Parent = TabBtn

    if iconId then
        local Icon = Instance.new("ImageLabel")
        Icon.Name = "Icon"
        Icon.Parent = TabBtn
        Icon.BackgroundTransparency = 1
        Icon.Position = UDim2.new(0, -22, 0.5, -7)
        Icon.Size = UDim2.new(0, 14, 0, 14)
        Icon.Image = "rbxassetid://" .. tostring(iconId)
    end

    -- สร้าง Page สำหรับ Tab นี้
    local page = Instance.new("ScrollingFrame")
    page.Name = name .. "Page"
    page.Parent = self.TabContainer
    page.BackgroundTransparency = 1
    page.BorderSizePixel = 0
    page.Size = UDim2.new(1, 0, 1, 0)
    page.CanvasSize = UDim2.new(0, 0, 0, 0)
    page.ScrollBarThickness = 3
    page.ScrollBarImageColor3 = Color3.fromRGB(80, 50, 150)
    page.Visible = false

    local layout = Instance.new("UIListLayout")
    layout.Parent = page
    layout.Padding = UDim.new(0, 6)
    layout.SortOrder = Enum.SortOrder.LayoutOrder

    local pad = Instance.new("UIPadding")
    pad.Parent = page
    pad.PaddingTop = UDim.new(0, 4)
    pad.PaddingLeft = UDim.new(0, 4)
    pad.PaddingRight = UDim.new(0, 4)

    layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
        page.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 8)
    end)

    self.Pages[name] = page

    -- ระบบกด Tab เปลี่ยนหน้า
    TabBtn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            self:RippleEffect(TabBtn, input)
        end
    end)

    TabBtn.MouseButton1Click:Connect(function()
        TweenService:Create(TabBtn, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundColor3 = Color3.fromRGB(80, 40, 200)
        }):Play()
        task.wait(0.08)
        TweenService:Create(TabBtn, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {
            BackgroundColor3 = Color3.fromRGB(25, 15, 40)
        }):Play()

        -- ซ่อนทุกหน้า แสดงหน้าตัวเอง
        for n, p in pairs(self.Pages) do
            p.Visible = (n == name)
        end
    end)

    -- คืนค่า Tab Object ออกไปเพื่อให้ใส่ Section ต่อได้
    local TabObject = {}
    TabObject.Page = page
    
    function TabObject:Section(titleText)
        return Library:CreateSection(page, titleText)
    end

    -- แสดง Tab แรกให้เป็นค่าเริ่มต้น
    if not self.FirstTab then
        self.FirstTab = true
        page.Visible = true
    end

    return TabObject
end

