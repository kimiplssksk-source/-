        arrow.Text = open and "^" or "v"
        local targetH = open and math.min(100, layout.AbsoluteContentSize.Y + 8) or 0
        TweenService:Create(wrap, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, 40 + targetH)}):Play()
        TweenService:Create(list, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, targetH)}):Play()
    end)

    for i, opt in ipairs(options) do
        local b = Instance.new("TextButton", list)
        b.Size = UDim2.new(1, 0, 0, 20)
        b.BackgroundTransparency = 1
        b.Text = opt
        b.Font = Enum.Font.Gotham
        b.TextSize = 11
        b.TextColor3 = Color3.fromRGB(200, 180, 240)
        b.TextXAlignment = Enum.TextXAlignment.Left
        Instance.new("UIPadding", b).PaddingLeft = UDim.new(0, 6)
        
        b.MouseButton1Click:Connect(function()
            current.Text = opt
            open = false
            arrow.Text = "v"
            TweenService:Create(wrap, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, 40)}):Play()
            TweenService:Create(list, TweenInfo.new(0.25), {Size = UDim2.new(1, 0, 0, 0)}):Play()
            if callback then callback(opt, i) end
        end)
    end
end

function Library:CreateButton(parent, buttonText, callback)
    local wrap = Instance.new("Frame")
    wrap.Parent = parent
    wrap.BackgroundTransparency = 1
    wrap.Size = UDim2.new(1, 0, 0, 28)

    local btn = Instance.new("TextButton")
    btn.Parent = wrap
    btn.Size = UDim2.new(1, 0, 1, 0)
    btn.AutoButtonColor = false
    btn.BackgroundColor3 = Color3.fromRGB(40, 20, 70)
    btn.Font = Enum.Font.GothamBold
    btn.Text = buttonText
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 11

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 5)
    corner.Parent = btn

    local btnGrad = Instance.new("UIGradient")
    btnGrad.Parent = btn
    btnGrad.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(80, 30, 140)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(30, 10, 60))
    })
    btnGrad.Rotation = 90

    btn.MouseEnter:Connect(function()
        TweenService:Create(btnGrad, TweenInfo.new(0.3), {Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(120, 40, 200)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(50, 20, 100))
        })}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btnGrad, TweenInfo.new(0.3), {Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(80, 30, 140)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(30, 10, 60))
        })}):Play()
    end)

    btn.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            self:RippleEffect(btn, input)
        end
    end)

    btn.MouseButton1Click:Connect(function()
        TweenService:Create(btnGrad, TweenInfo.new(0.1), {Color = ColorSequence.new(Color3.fromRGB(0, 200, 255))}):Play()
        task.wait(0.1)
        TweenService:Create(btnGrad, TweenInfo.new(0.2), {Color = ColorSequence.new({
            ColorSequenceKeypoint.new(0, Color3.fromRGB(80, 30, 140)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(30, 10, 60))
        })}):Play()
        if callback then callback() end
    end)
end
