    current.Parent = box
    current.BackgroundTransparency = 1
    current.Position = UDim2.new(0, 8, 0, 0)
    current.Size = UDim2.new(1, -24, 1, 0)
    current.Font = Enum.Font.GothamBold
    current.Text = options[defaultIndex] or options[1]
    current.TextColor3 = Color3.fromRGB(240, 240, 240)
    current.TextSize = 11
    current.TextXAlignment = Enum.TextXAlignment.Left

    local arrow = Instance.new("TextLabel")
    arrow.Parent = box
    arrow.BackgroundTransparency = 1
    arrow.Position = UDim2.new(1, -18, 0, 0)
    arrow.Size = UDim2.new(0, 16, 1, 0)
    arrow.Font = Enum.Font.GothamBold
    arrow.Text = "v"
    arrow.TextColor3 = Color3.fromRGB(180, 180, 180)
    arrow.TextSize = 11

    local list = Instance.new("Frame")
    list.Parent = wrap
    list.Position = UDim2.new(0, 0, 0, 44)
    list.Size = UDim2.new(1, 0, 0, 0)
    list.BackgroundColor3 = Color3.fromRGB(32, 32, 32)
    Instance.new("UICorner", list).CornerRadius = UDim.new(0, 5)
    Instance.new("UIStroke", list).Color = Color3.fromRGB(45, 45, 45)

