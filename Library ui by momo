    lbl.TextXAlignment = Enum.TextXAlignment.Left

    local box = Instance.new("TextButton")
    box.Parent = wrap
    box.Position = UDim2.new(0, 0, 0, 18)
    box.Size = UDim2.new(1, 0, 0, 22)
    box.Text = ""
    box.AutoButtonColor = false
